---
import { getProjects } from "@lib/queries";

const projects = await getProjects();
const CATEGORY_ORDER = [
  "Public",
  "Private",
  "Brand Direction",
  "Campaigns",
  "Exhibitions",
  "Editorial",
  "Films",
  "Lab",
  "Archive",
];
const present = new Set(projects.flatMap((p) => p.categories ?? []));
const categories = CATEGORY_ORDER.filter((c) => present.has(c));
---

<div class="wrap flex flex-wrap items-center gap-x-1.5 gap-y-1 pb-2">
  <button type="button" class="filter-btn is-active" data-filter="all"
    >All</button
  >
  {
    categories.map((c) => (
      <span class="inline-flex items-center gap-x-1.5 whitespace-nowrap">
        <span>/</span>
        <button type="button" class="filter-btn" data-filter={c}>
          {c}
        </button>
      </span>
    ))
  }
</div>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(
    "#grid [data-categories]",
  );

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      buttons.forEach((b) => b.classList.toggle("is-active", b === btn));
      cards.forEach((card) => {
        const cats = (card.dataset.categories ?? "").split("|");
        card.style.display =
          filter === "all" || cats.includes(filter ?? "") ? "" : "none";
      });
    });
  });
</script>
