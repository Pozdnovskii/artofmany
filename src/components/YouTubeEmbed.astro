---
import { youTubeId } from "@lib/media";

interface Props {
  url: string;
  title?: string;
}
const { url, title } = Astro.props;
const id = youTubeId(url);
const posterSrc = id ? `https://i.ytimg.com/vi/${id}/maxresdefault.jpg` : null;
const fallback = id ? `https://i.ytimg.com/vi/${id}/hqdefault.jpg` : "";
---

{
  id && (
    <div class="video-facade relative aspect-video w-full overflow-hidden bg-black" data-provider="youtube" data-id={id}>
      <img
        src={posterSrc}
        alt={title || "Video"}
        loading="lazy"
        onerror={`this.onerror=null;this.src='${fallback}'`}
        class="absolute inset-0 h-full w-full object-cover"
      />
      <button type="button" class="group absolute inset-0 grid place-items-center" aria-label="Play video">
        <span class="grid h-16 w-16 place-items-center rounded-full bg-white/90 shadow-lg transition-transform duration-200 group-hover:scale-105">
          <svg viewBox="0 0 24 24" class="h-6 w-6 translate-x-[2px] fill-black">
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
      </button>
    </div>
  )
}

<script>
  document.querySelectorAll<HTMLElement>(".video-facade").forEach((el) => {
    if (el.dataset.wired) return;
    el.dataset.wired = "1";
    el.querySelector("button")?.addEventListener("click", () => {
      const provider = el.dataset.provider;
      const id = el.dataset.id;
      const src =
        provider === "youtube"
          ? `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`
          : `https://player.vimeo.com/video/${id}?autoplay=1&byline=0&portrait=0`;
      const iframe = document.createElement("iframe");
      iframe.src = src;
      iframe.className = "absolute inset-0 h-full w-full";
      iframe.allow = "autoplay; fullscreen; picture-in-picture; encrypted-media";
      iframe.setAttribute("allowfullscreen", "");
      el.replaceChildren(iframe);
    });
  });
</script>
