---
import logo from "@assets/Artofmany_logo.png";

const path = Astro.url.pathname.replace(/\/$/, "");
const links = [
  { href: "/projects", label: "Projects", active: path === "/projects" },
  { href: "/about", label: "About", active: path === "/about" },
  { href: "/team", label: "Team", active: path === "/team" },
];
---

<header class="sticky top-0 z-20 bg-bg pt-[6px] pb-2 md:static md:pt-[20px]">
  <div class="wrap flex items-center justify-between gap-[30px]">
    <a href="/" aria-label="Artofmany — home" class="relative z-11 shrink-0">
      <img
        src={logo.src}
        width={logo.width}
        height={logo.height}
        alt="Artofmany"
        loading="eager"
        class="h-6.5 w-auto"
      />
    </a>

    <nav id="nav-menu" aria-label="Primary">
      {
        links.map((l, i) => (
          <>
            {i > 0 && <span class="max-md:hidden">/</span>}
            <a
              href={l.href}
              aria-current={l.active ? "page" : undefined}
              class:list={[
                "transition-colors leading-loose",
                l.active ? "text-accent" : "hover:text-accent",
              ]}
            >
              {l.label}
            </a>
          </>
        ))
      }
    </nav>

    <button
      id="nav-toggle"
      type="button"
      class="relative z-11 size-[44px] flex justify-center items-center cursor-pointer md:hidden"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Open menu"
    >
      <svg
        id="nav-icon"
        viewBox="0 0 24 24"
        class="size-2/3 transition-transform duration-300"
      >
        <path
          d="M12 5v14M5 12h14"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          fill="none"></path>
      </svg>
    </button>
  </div>
</header>

<script>
  const btn = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");
  const icon = document.getElementById("nav-icon");
  const mq = window.matchMedia("(min-width: 768px)");

  if (btn && menu) {
    let isOpen = false;

    if (!mq.matches) menu.setAttribute("inert", "");

    const openMenu = () => {
      isOpen = true;
      menu.classList.add("open");
      menu.removeAttribute("inert");
      icon?.classList.add("rotate-45");
      btn.setAttribute("aria-expanded", "true");
      btn.setAttribute("aria-label", "Close menu");
      document.body.style.overflow = "hidden";
      setTimeout(
        () => (menu.querySelector("a") as HTMLElement | null)?.focus(),
        50,
      );
    };

    const closeMenu = () => {
      isOpen = false;
      menu.classList.remove("open");
      icon?.classList.remove("rotate-45");
      btn.setAttribute("aria-expanded", "false");
      btn.setAttribute("aria-label", "Open menu");
      document.body.style.overflow = "";
      if (!mq.matches) menu.setAttribute("inert", "");
    };

    btn.addEventListener("click", () => (isOpen ? closeMenu() : openMenu()));
    menu
      .querySelectorAll("a")
      .forEach((a) => a.addEventListener("click", () => isOpen && closeMenu()));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) {
        closeMenu();
        btn.focus();
      }
    });

    mq.addEventListener("change", (e) => {
      if (e.matches) {
        menu.removeAttribute("inert");
        if (isOpen) closeMenu();
      } else if (!isOpen) {
        menu.setAttribute("inert", "");
      }
    });
  }
</script>
