---
import Base from "@layouts/Base.astro";
import PortableText from "@components/PortableText.astro";
import VimeoEmbed from "@components/VimeoEmbed.astro";
import { YouTube } from "@astro-community/astro-embed-youtube";
import CaseGrid from "@components/CaseGrid.astro";
import SanityImage from "@components/SanityImage.astro";
import { sanityClient } from "@lib/sanity";
import type { Project } from "@lib/queries";

export async function getStaticPaths() {
  const projects: Project[] = await sanityClient.fetch(
    `*[_type == "project" && defined(slug.current)] | order(order asc){
      _id, title, "slug": slug.current, categories, coverImage,
      description, videos, metaTitle, metaDescription,
      gallery[]{ ..., "dimensions": asset->metadata.dimensions }
    }`,
  );
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}
const { project } = Astro.props;
---

<Base
  title={project.metaTitle || `${project.title} — Artofmany`}
  description={project.metaDescription}
>
  <article aria-labelledby="case-title" class="mb-15">
    <h1 id="case-title" class="sr-only">{project.title}</h1>

    {
      project.description && (
        <PortableText
          value={project.description}
          class="wrap pb-6 md:pb-8 *:max-w-2xl"
        />
      )
    }

    <section aria-label="Media" class="flex flex-col gap-1">
      {
        (project.gallery ?? []).map((img, i) => (
          <SanityImage
            image={img}
            sizes="100vw"
            priority={i < 2}
            alt={img.alt || project.title}
            class="w-full"
            data-reveal={i >= 2 ? true : undefined}
          />
        ))
      }
      {
        (project.videos ?? []).map((v) => (
          <div data-reveal class="w-full">
            {v._type === "youtube" ? (
              <YouTube
                id={v.youtubeUrl!}
                title={project.title}
                class="aspect-video w-full"
              />
            ) : (
              <VimeoEmbed
                url={v.vimeoUrl!}
                poster={v.poster}
                title={project.title}
              />
            )}
          </div>
        ))
      }
    </section>
  </article>

  <CaseGrid />
</Base>
