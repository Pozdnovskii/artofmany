---
import Base from "@layouts/Base.astro";
import PortableText from "@components/PortableText.astro";
import CaseGrid from "@components/CaseGrid.astro";
import SlashList from "@components/SlashList.astro";
import { getAbout, getContact } from "@lib/queries";

const [about, contact] = await Promise.all([getAbout(), getContact()]);
const social = contact?.socialLinks ?? [];
const offices = about?.offices ?? [];

const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
---

<Base
  title="About — Artofmany"
  description="Artofmany is an interdisciplinary creative studio founded by Jofre Sanfeliu, with offices in Barcelona and Dubai."
>
  <section class="wrap pt-6 mb-15 flex flex-col gap-4 *:max-w-2xl">
    <h1 class="sr-only">About</h1>

    {about?.bio && <PortableText value={about.bio} class="space-y-3" />}

    {
      (social.length > 0 || offices.length > 0) && (
        <section aria-labelledby="contact-heading" class="flex flex-col gap-4">
          <h2 id="contact-heading" class="sr-only">Contact</h2>

          {social.length > 0 && (
            <SlashList
              class="mb-6"
              items={social.map((s) => ({
                url: s.url,
                label: cap(s.platform),
              }))}
            />
          )}

          {offices.length > 0 && (
            <ul class="flex flex-col gap-4">
              {offices.map((office) => (
                <li>
                  <h3>{office.city}</h3>
                  <address class="not-italic">
                    {office.address &&
                      (office.mapLink ? (
                        <a
                          href={office.mapLink}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="block w-fit whitespace-pre-line hover:text-accent"
                        >
                          {office.address}
                        </a>
                      ) : (
                        <span class="block whitespace-pre-line">
                          {office.address}
                        </span>
                      ))}
                    {office.phone && (
                      <a
                        href={`tel:${office.phone.replace(/\s+/g, "")}`}
                        class="block w-fit hover:text-accent"
                      >
                        {office.phone}
                      </a>
                    )}
                    {office.email && (
                      <a
                        href={`mailto:${office.email}`}
                        class="block w-fit hover:text-accent"
                      >
                        {office.email}
                      </a>
                    )}
                  </address>
                </li>
              ))}
            </ul>
          )}
        </section>
      )
    }
  </section>

  <CaseGrid />
</Base>
