---
import Base from "@layouts/Base.astro";
import CaseGrid from "@components/CaseGrid.astro";
import { getHomeVideoUrl } from "@lib/queries";

const videoUrl = await getHomeVideoUrl();
---

<Base title="Artofmany — Interdisciplinary Creative Studio">
  <h1 class="sr-only">Artofmany — interdisciplinary creative studio</h1>

  {
    videoUrl && (
      <video
        src={videoUrl}
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        class="aspect-video w-full object-cover mb-4"
      />
    )
  }

  <CaseGrid />
</Base>
