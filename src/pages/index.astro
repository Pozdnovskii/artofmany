---
import Base from "@layouts/Base.astro";
import CaseGrid from "@components/CaseGrid.astro";
import heroWebm from "@assets/hero.webm";
import heroMp4 from "@assets/hero.mp4";
import heroPoster from "@assets/hero-poster.jpg";
---

<Base title="Artofmany — Interdisciplinary Creative Studio">
  <h1 class="sr-only">Artofmany — interdisciplinary creative studio</h1>

  <video
    poster={heroPoster.src}
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    class="aspect-video w-full object-cover mb-4"
  >
    <source src={heroWebm} type="video/webm" />
    <source src={heroMp4} type="video/mp4" />
  </video>

  <CaseGrid />
</Base>
