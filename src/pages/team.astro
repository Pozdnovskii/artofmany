---
import Base from "@layouts/Base.astro";
import CaseGrid from "@components/CaseGrid.astro";
import SlashList from "@components/SlashList.astro";
import SanityImage from "@components/SanityImage.astro";
import { getTeam } from "@lib/queries";

const team = await getTeam();
---

<Base
  title="Team — Artofmany"
  description="The people behind Artofmany — Barcelona & Dubai."
>
  <section class="wrap pt-6 mb-15">
    <h1 class="sr-only">Team</h1>

    <ul class="flex max-w-2xl flex-col gap-15">
      {
        team.map((member, i) => {
          const contacts = member.contactLinks ?? [];
          return (
            <li>
              <article class="flex flex-col gap-y-4">
                <h2 class="-order-1">
                  {member.role ? `${member.name}, ${member.role}` : member.name}
                </h2>

                {member.bio && (
                  <div class="space-y-3">
                    {member.bio.split(/\n\n+/).map((p) => (
                      <p>{p}</p>
                    ))}
                  </div>
                )}

                <SanityImage
                  image={member.photo}
                  ratio={1}
                  widths={[600, 1200]}
                  sizes="260px"
                  priority={i === 0}
                  alt={member.photo.alt || member.name}
                  class="w-[260px] max-w-full -order-1"
                />
                {contacts.length > 0 && (
                  <address>
                    <SlashList items={contacts} />
                  </address>
                )}
              </article>
            </li>
          );
        })
      }
    </ul>
  </section>

  <CaseGrid />
</Base>
