# Sanity write token — used only by the content import scripts (scripts/*.mjs).
# Create at https://manage.sanity.io → project 4d6uk72c → API → Tokens (Editor).
SANITY_API_WRITE_TOKEN=

# Cloudflare deploy hook URL — POSTed by /api/deploy when the "Deploy" button in
# the Studio is clicked. Inlined at BUILD time (import.meta.env), so it must be
# set as a BUILD variable in the Cloudflare Workers project, not only here.
SANITY_DEPLOY_HOOK=
